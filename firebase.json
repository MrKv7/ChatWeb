{
  "hosting": {
    "site": "chatweb-kv7",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "indexx1.html",
      "indexx2.html",
      "README.md",
      ".env",
      ".env.example"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/Index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ]
  }
}